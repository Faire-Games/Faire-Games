    "This will permanently reset all Sudoku best times and puzzle counts." : {
      "comment" : "Confirmation dialog body warning the player that resetting records is permanent.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "سيؤدي هذا إلى إعادة تعيين جميع أفضل أوقات سودوكو وعدد الألغاز نهائيًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dies setzt alle Sudoku-Bestzeiten und Rätselzähler dauerhaft zurück."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Esto restablecerá permanentemente todos los mejores tiempos y los conteos de puzles de Sudoku."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cela réinitialisera définitivement tous les meilleurs temps et le nombre de puzzles Sudoku résolus."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "यह सभी सुडोकू सर्वश्रेष्ठ समय और पहेली गणना को स्थायी रूप से रीसेट कर देगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ini akan menghapus semua waktu terbaik dan jumlah teka-teki Sudoku secara permanen."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tutti i migliori tempi e i conteggi dei puzzle Sudoku verranno reimpostati definitivamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "数独のベストタイムとパズル数がすべてリセットされます。元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "모든 스도쿠 최고 기록과 퍼즐 수가 영구적으로 초기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Isto redefinirá permanentemente todos os melhores tempos e contagens de quebra-cabeças do Sudoku."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Все лучшие результаты и счётчики головоломок судоку будут безвозвратно сброшены."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "这将永久重置所有数独最佳时间和谜题数量。"
          }
        }
      }
    },
